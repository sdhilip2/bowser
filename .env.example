# Bowser v1 — environment template
# Copy to .env and fill in real values. Never commit .env.

# v1 no longer requires any API keys — Yahoo Finance (crude), Gaspy,
# MBIE, Google News RSS, and ExchangeRate-API are all public.

# Snapshot output target.
#   Local dev:  a filesystem path (default: frontend/public/data/snapshot.json)
#   Production: a GCS URI, e.g. gs://bowser-data/snapshot.json
SNAPSHOT_OUT=../frontend/public/data/snapshot.json
